name: Docker
on:
  push:
    branches: 
      - main
  workflow_dispatch:
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v4
      - name: build docker
        run: docker build -t demo-python .
      - name: build docker
        run: docker run -d -p 5000:5000 demo-python
